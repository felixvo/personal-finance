# Copy to .env and adjust. .env is gitignored; this example is committed.

# --- Local dev (throwaway Docker Postgres) ---
DATABASE_URL="postgresql://atlas:atlas@localhost:5432/atlas?schema=public"
DIRECT_URL="postgresql://atlas:atlas@localhost:5432/atlas?schema=public"

# --- Production (Neon) — set these in the Vercel dashboard, not here ---
# DATABASE_URL = Neon POOLED connection ("...-pooler.<region>.neon.tech..."), used at runtime.
# DIRECT_URL   = Neon DIRECT connection (no "-pooler"), used by `prisma migrate deploy`.

# Auth.js — generate with:  npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET="dev-only-change-me"
