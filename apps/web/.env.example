# Copy to .env and adjust. .env is gitignored; this example is committed.

# Local dev Postgres (matches the throwaway Docker container in the README).
DATABASE_URL="postgresql://atlas:atlas@localhost:5432/atlas?schema=public"

# Auth.js — generate a secret with: npx auth secret  (or: openssl rand -base64 32)
AUTH_SECRET="dev-only-change-me"
